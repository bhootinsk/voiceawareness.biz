# voiceawareness.ca — mirror of .biz (separate port + CMS copy)
SITE_DOMAIN=voiceawareness.ca
DOMAIN_ROOT=/var/www/vhosts/voiceawareness.ca
SERVICE_NAME=voiceawareness-ca
APP_PORT=3001
# After Plesk creates the domain, verify with: stat -c '%U' /var/www/vhosts/voiceawareness.ca/httpdocs
APP_USER=voiceawarenessca
APP_GROUP=psacln
REPO_URL=https://github.com/bhootinsk/voiceawareness.biz.git
BACKUP_PREFIX=vac
PUBLIC_URL=https://www.voiceawareness.ca
CMS_MIRROR_SOURCE=/var/www/vhosts/voiceawareness.biz/private/cms
