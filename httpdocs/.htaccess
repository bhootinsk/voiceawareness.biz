# Plesk: do NOT put ProxyPass or ProxyPreserveHost here — Apache returns 500.
# Configure proxy in Plesk → Apache & nginx Settings → Additional Apache directives:
#
# <IfModule mod_proxy.c>
#   ProxyPreserveHost On
#   ProxyPass / http://127.0.0.1:3000/
#   ProxyPassReverse / http://127.0.0.1:3000/
# </IfModule>
#
# Keep this file empty (or rename to .htaccess.bak on the server).
