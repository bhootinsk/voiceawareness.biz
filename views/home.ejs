<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body class="page-home">
  <%- include('partials/header') %>

  <section class="hero-section" style="--hero-copy-max-width: <%= home.layout.heroCopyMaxWidth %>px; --hero-eyebrow-size: <%= home.layout.heroEyebrowFontSize %>px; --hero-title-size: <%= home.layout.heroTitleFontSize %>px; --hero-image-max-width: <%= home.layout.heroImageMaxWidth %>px; --hero-gap: <%= home.layout.heroGap %>rem; --hero-button-padding-left: <%= home.layout.heroButtonPaddingLeft %>px;">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h2 class="hero-eyebrow"><%= home.heroEyebrow %></h2>
        <h1>
          <% (home.heroTitleLines || home.heroTitle.split(' ')).forEach(function(line, i) { %>
            <% if (i > 0) { %><br /><% } %><%= line %>
          <% }); %>
        </h1>
        <% if ((home.heroLeadItems || []).length) { %>
          <ul class="hero-lead-list">
            <% home.heroLeadItems.forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          </ul>
        <% } else if (home.heroLead) { %>
          <% home.heroLead.split('\n\n').forEach(function(p) { %>
            <p><%- p.replace('VoiceAwareness Psychotherapy', '<strong>VoiceAwareness Psychotherapy</strong>') %></p>
          <% }); %>
        <% } %>
        <a href="<%= home.heroButtonLink %>" class="btn btn-primary"><%= home.heroButtonText %></a>
      </div>
      <div class="hero-visual">
        <div class="hero-banner-wrap">
          <img src="<%= home.images.heroBanner || home.images.heroPortrait %>" alt="Therapy that meets you where you are" class="hero-banner" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="section about-section" id="about">
    <div class="container about-grid">
      <div class="about-copy">
        <p class="section-label">About</p>
        <h2><%= home.aboutTitle %></h2>
        <h4 class="about-subtitle"><strong><%= home.aboutSubtitle %></strong></h4>
        <div class="section-divider" aria-hidden="true"></div>
        <% home.aboutBody.split('\n\n').forEach(function(p) { %>
          <p><%= p %></p>
        <% }); %>
        <% if (home.consultationTitle) { %>
          <h3 class="consultation-heading"><strong><%= home.consultationTitle %></strong></h3>
          <p><%= home.consultationBody %></p>
        <% } %>
        <a href="<%= home.aboutButtonLink %>" class="btn btn-primary"><%= home.aboutButtonText %></a>
      </div>
      <div class="about-visual">
        <img src="<%= home.images.aboutPortrait %>" alt="<%= site.owner %> | Stress Management Therapy" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section services-section" id="services">
    <div class="container concern-areas-header">
      <p class="section-label center-label">Services</p>
      <h2 class="concern-areas-title"><%= home.servicesTitle %></h2>
      <div class="section-divider" aria-hidden="true"></div>
      <% if (home.servicesIntro) { %><p class="concern-areas-intro"><%= home.servicesIntro %></p><% } %>
    </div>
    <div class="container concern-areas-grid">
      <% (home.concernAreas || []).forEach(function(area) { %>
        <article class="concern-card">
          <i class="fas fa-heart concern-card-icon" aria-hidden="true"></i>
          <div>
            <h4><%= area.title %></h4>
            <p><%= area.summary %></p>
          </div>
        </article>
      <% }); %>
    </div>

    <div class="container split-row welcome-block">
      <div>
        <h3><strong><%= home.audienceTitle %></strong></h3>
        <p><%= home.audienceIntro %></p>
        <p><%= home.audienceFooter %></p>
        <% if (home.audienceButtonText) { %>
          <a href="<%= home.audienceButtonLink || '/calendar' %>" class="btn btn-primary section-cta"><%= home.audienceButtonText %></a>
        <% } %>
      </div>
      <div class="split-image">
        <img src="<%= home.images.audience %>" alt="" loading="lazy" />
      </div>
    </div>

    <div class="container home-subsection work-together-block">
      <div class="split-row reverse">
        <div class="split-image">
          <img src="<%= home.images.registered %>" alt="" loading="lazy" />
        </div>
        <div>
          <h3><strong><%= home.workTogetherTitle %></strong></h3>
          <p><%= home.workTogetherIntro %></p>
        </div>
      </div>
      <div class="info-card-grid cols-3">
        <% (home.workTogetherFeatures || []).forEach(function(item) { %>
          <article class="info-card">
            <i class="fas <%= item.icon %> info-card-icon" aria-hidden="true"></i>
            <div>
              <h4><%= item.title %></h4>
              <p><%= item.summary %></p>
            </div>
          </article>
        <% }); %>
      </div>
    </div>

    <div class="container home-subsection approach-block">
      <div class="split-row">
        <div>
          <h3><strong><%= home.approachesTitle %></strong></h3>
          <% home.approachesIntro.split('\n\n').forEach(function(p) { %>
            <p><%= p %></p>
          <% }); %>
        </div>
        <div class="split-image">
          <img src="<%= home.images.approaches %>" alt="" loading="lazy" />
        </div>
      </div>
      <div class="info-card-grid cols-2">
        <% (home.approachMethods || []).forEach(function(item) { %>
          <article class="info-card">
            <i class="fas <%= item.icon %> info-card-icon" aria-hidden="true"></i>
            <div>
              <h4><%= item.title %></h4>
              <p><%= item.summary %></p>
            </div>
          </article>
        <% }); %>
      </div>
      <p class="subsection-footer"><%= home.approachesFooter %></p>
    </div>

    <div class="container home-subsection virtual-therapy-block">
      <div class="virtual-therapy-header">
        <h3><strong><i class="fas fa-globe-americas virtual-globe-icon" aria-hidden="true"></i> <%= home.virtualTherapyTitle %></strong></h3>
        <p class="virtual-tagline"><strong><%= home.virtualTherapyTagline %></strong></p>
        <p><%= home.virtualTherapyIntro %></p>
      </div>
      <h4 class="virtual-subheading"><%= home.virtualTherapyWhyTitle %></h4>
      <div class="info-card-grid cols-4">
        <% (home.virtualTherapyBenefits || []).forEach(function(item) { %>
          <article class="info-card compact">
            <i class="fas <%= item.icon %> info-card-icon" aria-hidden="true"></i>
            <div>
              <h4><%= item.title %></h4>
              <p><%= item.summary %></p>
            </div>
          </article>
        <% }); %>
      </div>
      <div class="split-row reverse virtual-where-row">
        <div class="split-image">
          <img src="<%= home.images.jurisdiction %>" alt="" loading="lazy" />
        </div>
        <div>
          <h4><strong><%= home.virtualTherapyWhereTitle %></strong></h4>
          <p><%= home.virtualTherapyWhereBody %></p>
          <% if (home.virtualTherapyButtonText) { %>
            <a href="<%= home.virtualTherapyButtonLink || '/calendar' %>" class="btn btn-primary section-cta"><%= home.virtualTherapyButtonText %></a>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container">
      <h2 class="faq-heading"><i class="fas fa-heart faq-heart-icon" aria-hidden="true"></i> <%= home.faqsTitle %></h2>
      <div class="faq-accordion">
        <% (home.faqs || []).forEach(function(faq, i) { %>
          <div class="faq-toggle<%= i === 0 ? ' open' : '' %>">
            <button type="button" class="faq-question" aria-expanded="<%= i === 0 ? 'true' : 'false' %>">
              <%= faq.question %>
              <span class="faq-icon" aria-hidden="true"></span>
            </button>
            <div class="faq-answer">
              <p><%= faq.answer %></p>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <section class="section contact-section" id="bookafreeconsulation">
    <div class="container contact-layout">
      <div class="contact-copy">
        <% if (home.contactPsychologyHeading) { %>
          <h2>
            <a href="<%= site.psychologyToday %>" target="_blank" rel="noopener noreferrer"><%= home.contactPsychologyHeading %></a>
          </h2>
        <% } %>
        <h2 class="contact-phone-heading"><%= home.contactPhoneHeading %></h2>
        <form class="contact-form" method="post" action="/contact">
          <div class="form-row">
            <label>
              <span class="sr-only">First name</span>
              <input type="text" name="firstName" placeholder="First name" required />
            </label>
            <label>
              <span class="sr-only">Last name</span>
              <input type="text" name="lastName" placeholder="Last name" required />
            </label>
          </div>
          <div class="form-row">
            <label>
              <span class="sr-only">Email Address</span>
              <input type="email" name="email" placeholder="Email Address" required />
            </label>
            <label>
              <span class="sr-only">Phone</span>
              <input type="tel" name="phone" placeholder="Phone" />
            </label>
          </div>
          <label>
            <span class="sr-only">Message</span>
            <textarea name="message" rows="5" placeholder="Type your message here..." required></textarea>
          </label>
          <fieldset class="radio-group">
            <legend><%= home.contactLocationQuestion || 'Are you located in Canada?*' %></legend>
            <label><input type="radio" name="inOntario" value="yes" required /> Yes</label>
            <label><input type="radio" name="inOntario" value="no" /> No</label>
          </fieldset>
          <div class="form-footer">
            <p class="captcha-row">
              <span>7 + 10</span> =
              <input type="text" name="captcha" inputmode="numeric" pattern="17" title="Answer: 17" required autocomplete="off" />
            </p>
            <button type="submit" class="btn btn-primary">Submit</button>
          </div>
        </form>
      </div>
      <div class="contact-visual" aria-hidden="true"></div>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
