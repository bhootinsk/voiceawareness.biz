<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="<%= site.siteName %> home">
      <img src="/images/logo.png" alt="" class="logo-mark" width="48" height="48" />
      <span class="logo-text">
        <strong><%= site.siteName %></strong>
        <small><%= site.tagline %></small>
      </span>
    </a>
    <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="main-nav" aria-label="Main">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
      <a href="/my-approach" class="<%= currentPath === '/my-approach' ? 'active' : '' %>">My Approach</a>
      <div class="nav-dropdown">
        <button type="button" class="nav-dropdown-toggle <%= currentPath.includes('stress') || currentPath.includes('trauma') || currentPath.includes('emotional') || currentPath.includes('personal') ? 'active' : '' %>">Services</button>
        <div class="nav-dropdown-menu">
          <% (site.services || []).forEach(function(service) { %>
            <a href="<%= service.path %>"><%= service.title %></a>
          <% }); %>
        </div>
      </div>
      <a href="/blogs" class="<%= currentPath === '/blogs' ? 'active' : '' %>">Blogs</a>
      <a href="/calendar" class="<%= currentPath === '/calendar' ? 'active' : '' %>">Calendar</a>
      <a href="/#contact" class="nav-cta">Contact</a>
    </nav>
  </div>
</header>
