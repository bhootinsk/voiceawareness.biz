<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { metaDescription: 'Articles and insights on psychotherapy, mental health, and wellness from Voice Awareness.' }) %>
</head>
<body class="page-inner page-blogs">
  <%- include('partials/header') %>
  <main class="page-main">
    <section class="page-hero page-hero--has-image">
      <div class="container page-hero-grid">
        <div class="page-hero-copy">
          <p class="section-label">Insights</p>
          <h1>Blogs</h1>
          <p class="page-intro">Articles on psychotherapy, mental health, anxiety, trauma recovery, and personal growth.</p>
        </div>
        <div class="page-hero-image">
          <img src="/images/blog/blogs-hero.webp" alt="Voice Awareness blog" loading="eager" />
        </div>
      </div>
    </section>
    <section class="section section--content">
      <div class="container">
        <% if (posts.length) { %>
          <div class="blog-grid">
            <% posts.forEach(function(post) { %>
              <% const cardImg = post.cardImage || post.featuredImage || '/images/blog/anxiety-card.webp'; %>
              <article class="blog-card">
                <a href="<%= post.url %>" class="blog-card-image">
                  <img src="<%= cardImg %>" alt="<%= post.title %>" loading="lazy" />
                </a>
                <div class="blog-card-body">
                  <p class="post-meta">
                    <%= post.author || site.owner %>
                    <% if (post.publishedAt) { %> · <%= new Date(post.publishedAt).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' }) %><% } %>
                  </p>
                  <h2><a href="<%= post.url %>"><%= post.title %></a></h2>
                  <p><%= post.excerpt %></p>
                  <a href="<%= post.url %>" class="text-link">Read article →</a>
                </div>
              </article>
            <% }); %>
          </div>
        <% } else { %>
          <p class="empty-note">New posts will appear here soon.</p>
        <% } %>
        <div class="blogs-aside">
          <p>Connect on <a href="<%= site.psychologyToday %>" target="_blank" rel="noopener">Psychology Today</a> or <a href="<%= site.firstSession %>" target="_blank" rel="noopener">First Session</a>.</p>
          <a href="<%= site.janeApp %>" class="btn btn-primary" target="_blank" rel="noopener">Book on Jane App</a>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
