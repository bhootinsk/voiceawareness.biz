<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { metaDescription: page.metaDescription }) %>
</head>
<body class="page-inner page-service">
  <%- include('partials/header') %>
  <main class="page-main">
    <%- include('partials/page-hero', { heroLabelOverride: 'Service' }) %>
    <section class="section section--content">
      <div class="container content-body service-body">
        <%- page.html %>
        <div class="cta-panel">
          <h2>Ready to take the next step?</h2>
          <p>Book a free consultation to discuss whether this service is right for you.</p>
          <div class="cta-panel-actions">
            <a href="/calendar" class="btn btn-primary">Book online</a>
            <a href="<%= site.janeApp %>" class="btn btn-secondary" target="_blank" rel="noopener">Jane App</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
