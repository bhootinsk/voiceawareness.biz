<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | CMS</title>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-body">
  <main class="admin-main narrow">
    <h1>Admin Login</h1>
    <% if (error) { %><p class="error">Invalid username or password. Use username <strong>admin</strong> (from deploy-check). Check <code>.env</code> <code>ADMIN_PASSWORD</code>.</p><% } %>
    <% if (sessionLost) { %><p class="error">Your session was not saved. Sign in again. If this keeps happening, ask your host to add <code>X-Forwarded-Proto</code> on the Apache proxy.</p><% } %>
    <form method="post" action="/admin/login" class="admin-form">
      <input type="hidden" name="redirect" value="<%= redirect %>" />
      <label>Username <input type="text" name="user" autocomplete="username" required /></label>
      <label>Password <input type="password" name="pass" autocomplete="current-password" required /></label>
      <button type="submit" class="btn btn-primary">Sign in</button>
    </form>
  </main>
</body>
</html>
