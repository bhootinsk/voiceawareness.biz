<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | CMS</title>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-body">
  <%- include('../partials/admin-header') %>
  <main class="admin-main container">
    <h1>Edit Home Page</h1>
    <form method="post" action="/admin/home" class="admin-form">
      <fieldset>
        <legend>Hero</legend>
        <label>Eyebrow <input type="text" name="heroEyebrow" value="<%= home.heroEyebrow %>" /></label>
        <label>Title <input type="text" name="heroTitle" value="<%= home.heroTitle %>" /></label>
        <label>Lead <textarea name="heroLead" rows="5"><%= home.heroLead %></textarea></label>
      </fieldset>
      <fieldset>
        <legend>Hero layout (sliders)</legend>
        <p class="help">Fine-tune spacing and sizes. Changes apply immediately after save — no deploy needed.</p>
        <% const L = home.layout; %>
        <label class="range-label">
          Text block width <output id="out-heroCopyMaxWidth"><%= L.heroCopyMaxWidth %></output>px
          <input type="range" name="heroCopyMaxWidth" min="420" max="680" step="10" value="<%= L.heroCopyMaxWidth %>" data-output="out-heroCopyMaxWidth" data-suffix="px" />
        </label>
        <label class="range-label">
          Eyebrow font size <output id="out-heroEyebrowFontSize"><%= L.heroEyebrowFontSize %></output>px
          <input type="range" name="heroEyebrowFontSize" min="24" max="40" step="1" value="<%= L.heroEyebrowFontSize %>" data-output="out-heroEyebrowFontSize" data-suffix="px" />
        </label>
        <label class="range-label">
          Title font size <output id="out-heroTitleFontSize"><%= L.heroTitleFontSize %></output>px
          <input type="range" name="heroTitleFontSize" min="48" max="80" step="1" value="<%= L.heroTitleFontSize %>" data-output="out-heroTitleFontSize" data-suffix="px" />
        </label>
        <label class="range-label">
          Portrait image width <output id="out-heroImageMaxWidth"><%= L.heroImageMaxWidth %></output>px
          <input type="range" name="heroImageMaxWidth" min="400" max="600" step="10" value="<%= L.heroImageMaxWidth %>" data-output="out-heroImageMaxWidth" data-suffix="px" />
        </label>
        <label class="range-label">
          Gap between text and image <output id="out-heroGap"><%= L.heroGap %></output>rem
          <input type="range" name="heroGap" min="1" max="4" step="0.5" value="<%= L.heroGap %>" data-output="out-heroGap" data-suffix="rem" />
        </label>
        <label class="range-label">
          Booking button left padding <output id="out-heroButtonPaddingLeft"><%= L.heroButtonPaddingLeft %></output>px
          <input type="range" name="heroButtonPaddingLeft" min="100" max="160" step="2" value="<%= L.heroButtonPaddingLeft %>" data-output="out-heroButtonPaddingLeft" data-suffix="px" />
        </label>
      </fieldset>
      <fieldset>
        <legend>About Nayab</legend>
        <label>Title <input type="text" name="aboutTitle" value="<%= home.aboutTitle %>" /></label>
        <label>Subtitle <input type="text" name="aboutSubtitle" value="<%= home.aboutSubtitle %>" /></label>
        <label>Body <textarea name="aboutBody" rows="8"><%= home.aboutBody %></textarea></label>
      </fieldset>
      <fieldset>
        <legend>Services section</legend>
        <label>Title <input type="text" name="servicesTitle" value="<%= home.servicesTitle %>" /></label>
        <label>Intro <textarea name="servicesIntro" rows="3"><%= home.servicesIntro %></textarea></label>
      </fieldset>
      <fieldset>
        <legend>Audience &amp; approaches</legend>
        <label>Audience title <input type="text" name="audienceTitle" value="<%= home.audienceTitle %>" /></label>
        <label>Audience intro <input type="text" name="audienceIntro" value="<%= home.audienceIntro %>" /></label>
        <label>Audience items (one per line) <textarea name="audienceItems" rows="6"><%= (home.audienceItems || []).join('\n') %></textarea></label>
        <label>Approaches title <input type="text" name="approachesTitle" value="<%= home.approachesTitle %>" /></label>
        <label>Approaches items (one per line) <textarea name="approachesItems" rows="6"><%= (home.approachesItems || []).join('\n') %></textarea></label>
      </fieldset>
      <fieldset>
        <legend>FAQs</legend>
        <label>Section title <input type="text" name="faqsTitle" value="<%= home.faqsTitle %>" /></label>
        <label>FAQs (JSON array) <textarea name="faqsJson" rows="12" class="code-area"><%= JSON.stringify(home.faqs || [], null, 2) %></textarea></label>
      </fieldset>
      <button type="submit" class="btn btn-primary">Save home page</button>
    </form>
  </main>
  <script>
    document.querySelectorAll('input[type="range"][data-output]').forEach((input) => {
      const output = document.getElementById(input.dataset.output);
      const suffix = input.dataset.suffix || '';
      const sync = () => { output.textContent = input.value + suffix; };
      input.addEventListener('input', sync);
      sync();
    });
  </script>
</body>
</html>
