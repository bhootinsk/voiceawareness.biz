<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { metaDescription: page.metaDescription }) %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="page-main">
    <section class="page-banner">
      <div class="container">
        <h1><%= page.title %></h1>
        <% if (page.excerpt) { %><p class="page-intro"><%= page.excerpt %></p><% } %>
      </div>
    </section>
    <section class="section">
      <div class="container content-body <%= typeof wide !== 'undefined' && wide ? 'wide' : '' %>">
        <% if (page.slug === 'calendar') { %>
          <div class="calendar-embed">
            <iframe src="<%= site.calendarUrl %>" title="Book an appointment" loading="lazy"></iframe>
          </div>
        <% } %>
        <%- page.html %>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
