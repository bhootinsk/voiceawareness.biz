<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { metaDescription: page.metaDescription }) %>
</head>
<body class="page-inner<%= page.slug === 'approach' ? ' page-approach' : '' %>">
  <%- include('partials/header') %>
  <main class="page-main">
    <%- include('partials/page-hero') %>
    <section class="section section--content">
      <div class="container content-body <%= typeof wide !== 'undefined' && wide ? 'wide' : '' %>">
        <%- page.html %>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
