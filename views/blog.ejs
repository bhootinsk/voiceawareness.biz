<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { metaDescription: page.metaDescription }) %>
</head>
<body class="page-inner page-blog">
  <%- include('partials/header') %>
  <main class="page-main">
    <section class="page-hero">
      <div class="container page-hero-copy page-hero-copy--center">
        <p class="section-label">Blog</p>
        <h1><%= page.title %></h1>
        <% if (page.excerpt) { %><p class="page-intro"><%= page.excerpt %></p><% } %>
        <% if (page.publishedAt) { %>
          <p class="post-meta">By <%= page.author || site.owner %> · <%= new Date(page.publishedAt).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
        <% } %>
      </div>
    </section>
    <% if (page.featuredImage) { %>
      <section class="article-featured-banner">
        <div class="container">
          <img
            class="article-featured-img"
            src="<%= page.featuredImage %>"
            srcset="/images/blog/anxiety-card.webp 400w, <%= page.featuredImage %> 1080w"
            sizes="(max-width: 820px) 100vw, 760px"
            alt="<%= page.title %>"
            width="1080"
            height="675"
            loading="eager"
            decoding="async"
          />
        </div>
      </section>
    <% } %>
    <section class="section section--content">
      <div class="container content-body article-body">
        <%- page.html %>
        <div class="article-footer">
          <a href="/blogs" class="text-link">← Back to blogs</a>
          <a href="<%= site.janeApp %>" class="btn btn-primary" target="_blank" rel="noopener">Book a consultation</a>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
